# Copy this file to .env.local and fill in your key to enable the AI tutor
# and AI-powered flashcard enhancement. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: if set, every page requires this password (see /login).
# Leave blank for local dev. Set this before deploying publicly.
APP_PASSWORD=

# Optional: directory for the SQLite database file. Defaults to ./data.
# On Railway, set this to your volume's mount path (e.g. /data).
DATA_DIR=
